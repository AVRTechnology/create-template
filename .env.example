# Copy this file to .env.local and fill in your values

# Google Sheets Web App URL (see README for setup instructions)
# Get this from Google Apps Script deployment
GOOGLE_SHEET_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# Cloudinary credentials (Dashboard -> API Keys)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Optional: organize uploads in one folder
CLOUDINARY_FOLDER=parshuram-yatra
